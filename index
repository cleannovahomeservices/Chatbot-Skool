<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bot School</title>
  <style>
    :root{
      --bg: #0b1220;
      --card: rgba(255,255,255,.06);
      --card2: rgba(255,255,255,.10);
      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.72);
      --stroke: rgba(255,255,255,.10);
      --shadow: 0 20px 60px rgba(0,0,0,.35);
      --radius: 18px;
      --accent1: #6d5efc; /* violeta */
      --accent2: #22c55e; /* verde */
      --accent3: #06b6d4; /* cian */
      --danger: #ef4444;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }

    *{ box-sizing:border-box; }
    body{
      margin:0;
      font-family: var(--sans);
      color:var(--text);
      background:
        radial-gradient(1200px 800px at 10% 10%, rgba(109,94,252,.25), transparent 55%),
        radial-gradient(900px 700px at 90% 30%, rgba(6,182,212,.18), transparent 55%),
        radial-gradient(900px 700px at 50% 100%, rgba(34,197,94,.12), transparent 55%),
        var(--bg);
      min-height: 100svh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding: 28px 14px;
    }

    .app{
      width: min(980px, 100%);
      display:grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 18px;
    }

    @media (max-width: 860px){
      .app{ grid-template-columns: 1fr; }
    }

    .panel{
      background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.04));
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow:hidden;
      backdrop-filter: blur(10px);
    }

    .header{
      padding: 18px 18px 14px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 12px;
      border-bottom: 1px solid var(--stroke);
    }

    .brand{
      display:flex;
      align-items:center;
      gap: 12px;
      min-width:0;
    }

    .logo{
      width: 40px; height: 40px;
      border-radius: 14px;
      background: conic-gradient(from 180deg, var(--accent1), var(--accent3), var(--accent2), var(--accent1));
      box-shadow: 0 10px 25px rgba(109,94,252,.22);
      border: 1px solid rgba(255,255,255,.18);
    }

    .titlewrap{ min-width:0; }
    .title{
      font-weight: 800;
      letter-spacing: .2px;
      margin:0;
      font-size: 16px;
      line-height:1.2;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .subtitle{
      margin: 3px 0 0;
      font-size: 12px;
      color: var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .pill{
      font-size: 12px;
      padding: 8px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.06);
      border: 1px solid var(--stroke);
      color: var(--muted);
      display:flex;
      align-items:center;
      gap: 8px;
      user-select:none;
      white-space:nowrap;
    }
    .dot{
      width: 8px; height: 8px;
      border-radius: 999px;
      background: #94a3b8;
      box-shadow: 0 0 0 4px rgba(148,163,184,.12);
    }
    .dot.ok{
      background: #22c55e;
      box-shadow: 0 0 0 4px rgba(34,197,94,.14);
    }
    .dot.bad{
      background: var(--danger);
      box-shadow: 0 0 0 4px rgba(239,68,68,.12);
    }

    .chat{
      height: 520px;
      display:flex;
      flex-direction:column;
    }

    .messages{
      padding: 16px;
      overflow:auto;
      flex:1;
    }

    .msg{
      display:flex;
      gap: 10px;
      margin: 0 0 12px 0;
      align-items:flex-end;
    }
    .msg.user{ justify-content:flex-end; }
    .bubble{
      max-width: 86%;
      padding: 12px 12px;
      border-radius: 16px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.06);
      line-height: 1.35;
      font-size: 14px;
      white-space: pre-wrap;
      word-wrap: break-word;
    }
    .msg.user .bubble{
      background: linear-gradient(135deg, rgba(109,94,252,.32), rgba(6,182,212,.22));
      border-color: rgba(255,255,255,.14);
    }

    .meta{
      font-size: 11px;
      color: rgba(255,255,255,.55);
      margin-top: 6px;
      display:flex;
      gap: 10px;
      align-items:center;
    }

    .composer{
      padding: 12px;
      border-top: 1px solid var(--stroke);
      background: rgba(0,0,0,.12);
      display:flex;
      gap: 10px;
      align-items:flex-end;
    }

    textarea{
      resize:none;
      width:100%;
      min-height: 44px;
      max-height: 140px;
      padding: 12px 12px;
      border-radius: 14px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.05);
      color: var(--text);
      outline: none;
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.35;
    }
    textarea:focus{
      border-color: rgba(109,94,252,.45);
      box-shadow: 0 0 0 4px rgba(109,94,252,.12);
    }

    .btn{
      border: 1px solid rgba(255,255,255,.14);
      background: linear-gradient(135deg, rgba(109,94,252,.50), rgba(34,197,94,.28));
      color: white;
      padding: 11px 14px;
      border-radius: 14px;
      font-weight: 700;
      cursor:pointer;
      transition: transform .04s ease, opacity .2s ease;
      user-select:none;
      min-width: 92px;
    }
    .btn:active{ transform: translateY(1px); }
    .btn:disabled{ opacity:.55; cursor:not-allowed; }

    .side{
      padding: 16px;
    }

    .card{
      padding: 14px;
      border-radius: 16px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.05);
      margin-bottom: 12px;
    }

    .card h3{
      margin: 0 0 8px;
      font-size: 14px;
      letter-spacing:.2px;
    }

    .card p{
      margin:0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .code{
      margin-top: 10px;
      padding: 10px 10px;
      border-radius: 14px;
      background: rgba(0,0,0,.22);
      border: 1px solid var(--stroke);
      font-family: var(--mono);
      font-size: 12px;
      color: rgba(255,255,255,.82);
      overflow:auto;
    }

    .small{
      font-size: 12px;
      color: rgba(255,255,255,.62);
      margin-top: 10px;
      line-height: 1.35;
    }

    a{ color: rgba(255,255,255,.88); }
  </style>
</head>

<body>
  <div class="app">
    <!-- CHAT -->
    <div class="panel chat" role="application" aria-label="Bot School Chat">
      <div class="header">
        <div class="brand">
          <div class="logo" aria-hidden="true"></div>
          <div class="titlewrap">
            <p class="title">Bot School</p>
            <p class="subtitle">Resuelve dudas al instante (n8n webhook)</p>
          </div>
        </div>
        <div class="pill" id="statusPill" title="Estado de conexión">
          <span class="dot" id="statusDot" aria-hidden="true"></span>
          <span id="statusText">Listo</span>
        </div>
      </div>

      <div class="messages" id="messages" aria-live="polite"></div>

      <div class="composer">
        <textarea id="input" placeholder="Escribe tu duda… (Enter para enviar, Shift+Enter para salto de línea)"></textarea>
        <button class="btn" id="sendBtn">Enviar</button>
      </div>
    </div>

    <!-- SIDE INFO -->
    <div class="panel side">
      <div class="card">
        <h3>Webhook conectado</h3>
        <p>Esta página envía tu mensaje a n8n con <b>fetch</b> y muestra la respuesta del workflow.</p>
        <div class="code" id="hookUrlBox"></div>
        <div class="small">
          Si al publicar en GitHub Pages te falla por CORS, activa CORS en el Webhook node de n8n o usa un proxy/Cloudflare.
        </div>
      </div>

      <div class="card">
        <h3>Formato esperado</h3>
        <p>
          La app enviará:
        </p>
        <div class="code">POST JSON: { "message": "..." }</div>
        <p style="margin-top:10px;">
          Y entiende respuestas tipo:
        </p>
        <div class="code">
{ "reply": "..." }  ó  { "message": "..." }  ó texto plano
        </div>
      </div>

      <div class="card">
        <h3>Tip de seguridad (recomendado)</h3>
        <p>
          Añade una “clave” simple (token) en el workflow para que no cualquiera use tu webhook cuando esté público.
        </p>
        <div class="code">Header sugerido: x-bot-token: TU_TOKEN</div>
      </div>
    </div>
  </div>

  <script>
    // ✅ Tu webhook de n8n
    const WEBHOOK_URL = "https://n8n-n8n.3asuar.easypanel.host/webhook/f2a876f5-b691-4fcf-aaa6-4c42ca0739f2/chat";

    // (Opcional) Si quieres protegerlo con token:
    // const BOT_TOKEN = "CAMBIA_ESTO";
    const BOT_TOKEN = ""; // déjalo vacío si no lo usas

    const elMessages = document.getElementById("messages");
    const elInput = document.getElementById("input");
    const elSend = document.getElementById("sendBtn");
    const statusDot = document.getElementById("statusDot");
    const statusText = document.getElementById("statusText");
    const hookUrlBox = document.getElementById("hookUrlBox");

    hookUrlBox.textContent = WEBHOOK_URL;

    function setStatus(kind, text){
      statusDot.classList.remove("ok","bad");
      if(kind === "ok") statusDot.classList.add("ok");
      if(kind === "bad") statusDot.classList.add("bad");
      statusText.textContent = text;
    }

    function nowTime(){
      const d = new Date();
      return d.toLocaleTimeString([], {hour:"2-digit", minute:"2-digit"});
    }

    function addMessage(role, text){
      const wrap = document.createElement("div");
      wrap.className = "msg " + (role === "user" ? "user" : "bot");

      const bubble = document.createElement("div");
      bubble.className = "bubble";
      bubble.textContent = text;

      wrap.appendChild(bubble);
      elMessages.appendChild(wrap);

      const meta = document.createElement("div");
      meta.className = "meta";
      meta.style.justifyContent = role === "user" ? "flex-end" : "flex-start";
      meta.textContent = `${role === "user" ? "Tú" : "Bot"} · ${nowTime()}`;
      elMessages.appendChild(meta);

      elMessages.scrollTop = elMessages.scrollHeight;
      return {wrap, bubble, meta};
    }

    function autoGrow(textarea){
      textarea.style.height = "auto";
      textarea.style.height = Math.min(textarea.scrollHeight, 140) + "px";
    }

    async function sendMessage(){
      const msg = elInput.value.trim();
      if(!msg) return;

      elInput.value = "";
      autoGrow(elInput);

      addMessage("user", msg);
      const pending = addMessage("bot", "Pensando…");

      elSend.disabled = true;
      setStatus("", "Enviando…");

      try{
        const headers = {
          "Content-Type": "application/json",
          "Accept": "application/json, text/plain;q=0.9, */*;q=0.8"
        };
        if(BOT_TOKEN) headers["x-bot-token"] = BOT_TOKEN;

        const res = await fetch(WEBHOOK_URL, {
          method: "POST",
          headers,
          body: JSON.stringify({ message: msg })
        });

        const contentType = (res.headers.get("content-type") || "").toLowerCase();
        let replyText = "";

        if(contentType.includes("application/json")){
          const data = await res.json();
          replyText = (data && (data.reply ?? data.message ?? data.text)) ? String(data.reply ?? data.message ?? data.text) : JSON.stringify(data, null, 2);
        } else {
          replyText = await res.text();
        }

        if(!res.ok){
          replyText = `Error HTTP ${res.status}: ` + replyText;
          setStatus("bad", "Error");
        } else {
          setStatus("ok", "Conectado");
        }

        pending.bubble.textContent = replyText || "No recibí respuesta del servidor.";
      } catch (err){
        setStatus("bad", "Sin conexión");
        pending.bubble.textContent =
          "No pude conectar con el webhook. Si estás en GitHub Pages, probablemente es CORS.\n\n" +
          "Detalles: " + (err?.message || String(err));
      } finally {
        elSend.disabled = false;
        elInput.focus();
      }
    }

    // Mensaje inicial
    addMessage("bot", "Hola 👋 Soy Bot School. Escríbeme tu duda y la envío a n8n.");

    elSend.addEventListener("click", sendMessage);
    elInput.addEventListener("input", () => autoGrow(elInput));
    elInput.addEventListener("keydown", (e) => {
      if(e.key === "Enter" && !e.shiftKey){
        e.preventDefault();
        sendMessage();
      }
    });
  </script>
</body>
</html>
